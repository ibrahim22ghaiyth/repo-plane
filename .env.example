# انسخ هذا الملف إلى .env واملأ القيم
# Copy this file to .env and fill in the values

# مفتاح Anthropic API (سرّي — لا ترفعه على GitHub)
# Anthropic API key (secret — never commit it)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# (اختياري) اسم النموذج / optional model name
ANTHROPIC_MODEL=claude-sonnet-4-6

# (اختياري) إذا تستخدم خادماً خارجياً للذكاء الاصطناعي بدل /api/chat
# (optional) external AI endpoint instead of /api/chat
# VITE_AI_ENDPOINT=https://your-api.example.com/chat
